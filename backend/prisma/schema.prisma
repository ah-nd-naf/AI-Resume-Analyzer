generator client {
  provider  = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id        String   @id @default(uuid())
  filename  String
  content   String
  userId    String?  //  This will store the Clerk User ID
  createdAt DateTime @default(now())
}

